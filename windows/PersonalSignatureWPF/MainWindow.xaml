<Window x:Class="PersonalSignatureWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalSignatureWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True">
    <Grid>
        <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="2" />
            </Border.Effect>
            <StackPanel Margin="20">
                <TextBlock Text="Personal Signature" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBlock Text="Ready for Phase 3" Foreground="LightGray" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
