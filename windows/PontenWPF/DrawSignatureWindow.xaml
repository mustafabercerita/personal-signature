<Window x:Class="PontenWPF.DrawSignatureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Draw Signature" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/Ponten.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border BorderBrush="LightGray" BorderThickness="1" Margin="10" Background="White">
            <InkCanvas x:Name="SignatureCanvas" Background="Transparent" />
        </Border>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,10,10">
            <Button Content="Clear" Width="80" Padding="5" Margin="0,0,10,0" Click="Clear_Click"/>
            <Button Content="Cancel" Width="80" Padding="5" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Padding="5" Background="#007ACC" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
