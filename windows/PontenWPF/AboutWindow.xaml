<Window x:Class="PontenWPF.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Ponten" Height="320" Width="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#1E1E1E">
    <Border Padding="16" BorderBrush="#333333" BorderThickness="1">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Image Source="pack://application:,,,/Assets/Ponten.ico" Width="36" Height="36" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Ponten" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText" Foreground="#AAAAAA" FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#333333" Margin="0,0,0,10"/>

            <TextBlock Text="Lightweight cross-platform app — one-click digital signature to clipboard. Built with C# &amp; WPF."
                       Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock Text="Global shortcut: Ctrl+Alt+S" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>

            <TextBlock Margin="0,0,0,10">
                <Hyperlink x:Name="GitHubLink" Foreground="#6CB4EE" RequestNavigate="GitHubLink_RequestNavigate">
                    View on GitHub →
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="MIT License · Open Source" Foreground="#888888" FontSize="11"/>
        </StackPanel>
    </Border>
</Window>